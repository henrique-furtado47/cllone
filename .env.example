# ==============================================================
# Copie este arquivo para .env e preencha as variáveis
#   cp .env.example .env
# ==============================================================

# ---- Django ----
SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria
DEBUG=False

# IPs/domínios permitidos (separados por vírgula, sem espaço)
# Inclua o IP público ou domínio da sua instância EC2 / ALB
ALLOWED_HOSTS=localhost,127.0.0.1,SEU_IP_OU_DOMINIO

# Origens CORS permitidas (URL completa, separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost,https://SEU_DOMINIO

# Origens confiáveis para o CSRF (necessário se usar HTTPS via ALB)
# Inclua https://seu-dominio.com ou http://seu-ip quando usar HTTP
CSRF_TRUSTED_ORIGINS=https://SEU_DOMINIO

# ---- Banco de dados PostgreSQL ----
POSTGRES_DB=cllone
POSTGRES_USER=cllone
POSTGRES_PASSWORD=troque-por-uma-senha-forte-aqui
