# Copie para terraform.tfvars e ajuste os caminhos das suas chaves SSH.
#   cp terraform.tfvars.example terraform.tfvars
#
# Gere um par de chaves antes (se ainda não tiver):
#   ssh-keygen -t ed25519 -f ~/.ssh/cllone -N ""

aws_region           = "us-east-1"
project_name         = "cllone"
instance_type        = "t3.medium"
worker_count         = 3
key_name             = "cllone-key"
ssh_public_key_path  = "~/.ssh/cllone.pub"
ssh_private_key_path = "~/.ssh/cllone"

# Restrinja o SSH ao seu IP para mais segurança, ex.: "203.0.113.10/32"
ssh_ingress_cidr = "0.0.0.0/0"
