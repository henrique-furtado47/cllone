# Inventory gerado automaticamente pelo Terraform - NÃO editar à mão.
# (regenerado a cada `terraform apply`)

[server]
${control_plane_public_ip} private_ip=${control_plane_private_ip}

[agents]
%{ for ip in worker_public_ips ~}
${ip}
%{ endfor ~}

[all:vars]
ansible_user=ubuntu
ansible_ssh_private_key_file=${ssh_private_key_file}
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'
control_plane_private_ip=${control_plane_private_ip}
control_plane_public_ip=${control_plane_public_ip}
